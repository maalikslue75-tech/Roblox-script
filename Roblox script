-- Instant Action mit Cooldown (für eigenes Roblox-Spiel)

local item = workspace:WaitForChild("StealItem")
local prompt = item:WaitForChild("ProximityPrompt")

local COOLDOWN = 10
local cooldowns = {}

prompt.Triggered:Connect(function(player)
    local id = player.UserId
    if cooldowns[id] then return end

    cooldowns[id] = true

    local tool = Instance.new("Tool")
    tool.Name = "GestohlenesItem"
    tool.Parent = player:WaitForChild("Backpack")

    prompt.Enabled = false
    item.Transparency = 1
    item.CanCollide = false

    task.delay(COOLDOWN, function()
        cooldowns[id] = nil
        prompt.Enabled = true
        item.Transparency = 0
        item.CanCollide = true
    end)
end)
